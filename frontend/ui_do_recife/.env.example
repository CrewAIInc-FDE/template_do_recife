# CrewAI AMP deployment of do_recife_chat_flow.
# Base URL of the deployment (used to call /kickoff, /inputs, /status/{id}).
DEPLOYMENT_URL=
# AMP API key, sent as the bearer token on outbound calls to the deployment.
DEPLOYMENT_KEY=
# Shared secret AMP must send back as the bearer token on inbound webhooks.
# The UI generates the value it expects; set the same value here.
WEBHOOK_TOKEN=

# Optional. Public HTTPS base URL AMP should call back for realtime webhooks.
# Leave empty to derive it per-request from the incoming host (works on Heroku).
# Locally, set it to your ngrok URL (e.g. https://do-recife.ngrok.app).
PUBLIC_BASE_URL=

# Dev only (read by bin/start). Your reserved ngrok domain that exposes the
# local Flask server so AMP can deliver webhooks.
NGROK_DOMAIN=do-recife.ngrok.app
# Local Flask/gunicorn port.
PORT=5005
