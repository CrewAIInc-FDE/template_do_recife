    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Embedder",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/crews/do_recife_embedder/src/do_recife_embedder/main.py",
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/.venv/bin/python",
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "Python Debugger: Chat Crew",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/crews/do_recife_chat_crew/src/do_recife_chat_crew/main.py",
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/.venv/bin/python",
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "Python Debugger: Chat Flow",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/crews/do_recife_chat_flow/src/do_recife_chat_flow/main.py",
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/.venv/bin/python",
            "envFile": "${workspaceFolder}/.env"
        }
    ]
}
